exec guix shell \
		 --container --emulate-fhs --network --no-cwd \
		 --root=$GUIX_EXTRA_PROFILES/rust/hell \
		 --preserve='^WAYLAND_DISPLAY$|^XDG_' --expose=$XDG_RUNTIME_DIR \
		 --preserve='^DBUS_' --expose=/var/run/dbus \
		 --preserve='^SHELL$' \
		 --preserve='^LD_LIBRARY_PATH$' --preserve='^LIBRARY_PATH$' \
		 --preserve='^CARGO_TARGET_DIR$' --preserve='^TMPDIR$' \
		 --preserve='^GIT_TEMPLATE_DIR$' \
		 --preserve='^PATH$' \
		 --preserve='^BROWSER$' \
		 --share=$HOME/alchemy/darkness/rust=$HOME \
		 --share=$HOME/.config/emacs \
		 --share=$HOME/.mozilla \
		 --manifest=$HOME/alchemy/darkness/rust/manifest.scm \
		 -- \
		 sh -l -c "emacs"
