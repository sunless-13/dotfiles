#!/usr/bin/env bash

exec guix shell \
		 --container --emulate-fhs --network --no-cwd \
		 --preserve='^LD_LIBRARY_PATH$' \
		 --preserve='^LIBRARY_PATH$' \
		 --preserve='^GIT_TEMPLATE_DIR$' \
		 --preserve='^PATH$' \
		 --preserve='^PWD$' \
		 --preserve='^TERM$' \
		 --preserve='^CARGO_TARGET_DIR$' \
		 --preserve='^TMPDIR$' \
		 --preserve='^BROWSER$' \
		 --preserve='^WAYLAND_DISPLAY$|^XDG_' --expose=$XDG_RUNTIME_DIR \
		 --preserve='^DBUS_' --expose=/var/run/dbus \
		 --share=$HOME/alchemy/darkness/dev-rust=$HOME \
		 --manifest=$HOME/alchemy/darkness/dev-rust/manifest.scm \
		 -- \
		 sh -l -c "mdbook-admonish $@"
